DATABASE_URL=postgresql://contachile:contachile@localhost:5432/contachile
BETTER_AUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32
REDIS_HOST=localhost
REDIS_PORT=6379
SII_BASE_URL=https://maullin.sii.cl
SII_ENV=test
ACEPTA_API_KEY=test-key

# ── DTE Polling Simulation (development only) ──
# Set to 'true' to simulate SII/Acepta status transitions without real HTTP calls
SIMULATE_DTE_STATUS=true
# Number of polling attempts before forcing ACCEPTED in simulation mode
SIMULATED_ATTEMPTS=3

# ── Fintoc (bancos) ──
FINTOC_SECRET_KEY=
FINTOC_BASE_URL=https://api.fintoc.com/v1
FINTOC_USE_REAL=false
