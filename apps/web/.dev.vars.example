# Requerido por @opennextjs/cloudflare en dev
NEXTJS_ENV=development

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
WEB_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Base de datos (Neon connection string)
DATABASE_URL=

# API Fastify
NEXT_PUBLIC_API_URL=http://localhost:3001

# Anthropic
ANTHROPIC_API_KEY=

# Email (Resend) — recuperación de contraseña. Sin esto el email de reset es no-op (se loguea).
RESEND_API_KEY=
EMAIL_FROM=ContaChile <noreply@contachile.cl>
