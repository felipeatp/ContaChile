# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=contai
POSTGRES_PASSWORD=CAMBIAR_POR_CONTRASEÑA_SEGURA
POSTGRES_DB=contai
# Dentro de Docker Compose, el host es "postgres" (nombre del servicio)
DATABASE_URL=postgresql://contai:CAMBIAR_POR_CONTRASEÑA_SEGURA@postgres:5432/contai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_POR_CONTRASEÑA_REDIS
# Dentro de Docker Compose, el host es "redis" (nombre del servicio)
REDIS_URL=redis://:CAMBIAR_POR_CONTRASEÑA_REDIS@redis:6379

# ── Better Auth ───────────────────────────────────────────────────────────────
# CRÍTICO: mismo valor en web y api para que las sesiones funcionen
BETTER_AUTH_SECRET=CAMBIAR_POR_STRING_ALEATORIO_32_CHARS_MINIMO

# ── Cifrado de certificados digitales (OBLIGATORIO) ───────────────────────────
# 64-char hex (32 bytes). Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CERT_ENCRYPTION_KEY=GENERAR_64_CHARS_HEX
BETTER_AUTH_URL=https://contai.innovatio-it.com

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://contai.innovatio-it.com
# NEXT_PUBLIC_API_URL se sobreescribe en docker-compose.prod.yml a http://api:3001

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Callback URL a configurar en Google Cloud Console:
# https://contai.innovatio-it.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — Microsoft ─────────────────────────────────────────────────────────
# Callback URL a configurar en Azure AD:
# https://contai.innovatio-it.com/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── Anthropic (IA) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Resend (email transaccional) ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@innovatio-it.com

# ── Fintoc (open banking) ────────────────────────────────────────────────────
FINTOC_SECRET_KEY=

# ── Almacenamiento DTE (elegir uno) ──────────────────────────────────────────
# Opción A: Cloudflare R2 (S3-compatible, gratis hasta 10GB)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=contai-dte

# Opción B: MinIO self-hosted (agregar servicio al docker-compose.prod.yml)
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=contai-dte
